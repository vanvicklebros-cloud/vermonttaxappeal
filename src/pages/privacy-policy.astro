---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteData from '../data/site.json';
---

<BaseLayout
  title="Privacy Policy | VermontTaxAppeal.com"
  description="Privacy policy for VermontTaxAppeal.com. Learn how we handle your data for Vermont property tax grievance services."
>

  <!-- HERO -->
  <section class="relative py-24 px-6 overflow-hidden grid-bg">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] opacity-15"
           style="background: radial-gradient(ellipse, #f97316 0%, transparent 70%);"></div>
    </div>
    <div class="relative max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight leading-tight mb-4">Privacy Policy</h1>
      <p class="text-slate-400 text-lg">Effective as of April 9, 2026</p>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto prose-dark">
      <div class="space-y-8">

        <div>
          <h2 class="text-2xl font-black text-white mb-3">Overview</h2>
          <p class="text-slate-400 leading-relaxed">
            {siteData.name} ("we," "us," or "our") operates the {siteData.name} website. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website and use our property tax grievance services.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-black text-white mb-3">What Information We Collect</h2>
          <h3 class="text-lg font-bold text-orange-400 mb-2">From Our Contact Form</h3>
          <p class="text-slate-400 leading-relaxed mb-4">
            When you submit your free property tax assessment request through our contact form, we collect:
          </p>
          <ul class="text-slate-400 space-y-2 ml-4 mb-4">
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Full name</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Email address</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Phone number (optional)</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Property address</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>County and parcel/taxpayer ID (optional)</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Property type (residential or commercial)</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Additional details you provide about your property</span>
            </li>
          </ul>
          <h3 class="text-lg font-bold text-orange-400 mb-2">Automatically Collected Information</h3>
          <p class="text-slate-400 leading-relaxed">
            We may automatically collect certain information about your device and browsing activity, including IP address, browser type, device type, and pages visited. This information helps us understand how our website is used and to improve our service.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-black text-white mb-3">How We Use Your Information</h2>
          <p class="text-slate-400 leading-relaxed mb-4">We use the information we collect for the following purposes:</p>
          <ul class="text-slate-400 space-y-2 ml-4">
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>To provide you with a free property tax assessment and grievance evaluation</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>To respond to your inquiries and provide customer support</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>To communicate with you about our services and potential next steps</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>To maintain and improve our website and service quality</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>To comply with legal obligations and prevent fraud</span>
            </li>
          </ul>
        </div>

        <div>
          <h2 class="text-2xl font-black text-white mb-3">Form Submissions & Netlify Forms</h2>
          <p class="text-slate-400 leading-relaxed">
            Our contact form is powered by Netlify Forms, a third-party service that handles form submissions. When you submit our form, your data is transmitted to Netlify for processing. Netlify stores form submissions temporarily to allow us to access and respond to them. We do not use Netlify for any other purpose. For more information about how Netlify handles data, please visit Netlify's Privacy Policy.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-black text-white mb-3">We Do Not Sell Your Data</h2>
          <p class="text-slate-400 leading-relaxed">
            We never sell, trade, rent, or share your personal information with third parties for their marketing purposes. Your data is confidential and used solely to evaluate and serve your property tax grievance needs.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-black text-white mb-3">Data Security</h2>
          <p class="text-slate-400 leading-relaxed">
            We implement appropriate technical and organizational measures to protect your information against unauthorized access, alteration, disclosure, or destruction. However, no method of transmission over the internet or electronic storage is 100% secure. We cannot guarantee absolute security but commit to protecting your data to the best of our ability.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-black text-white mb-3">Your Rights & Choices</h2>
          <p class="text-slate-400 leading-relaxed mb-4">You have the right to:</p>
          <ul class="text-slate-400 space-y-2 ml-4 mb-4">
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Request access to the personal information we hold about you</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Request correction of inaccurate or incomplete information</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Request deletion of your information (subject to legal requirements)</span>
            </li>
            <li class="flex gap-2">
              <span class="text-orange-400 shrink-0">•</span>
              <span>Opt out of future communications from us</span>
            </li>
          </ul>
          <p class="text-slate-400 leading-relaxed">
            To exercise any of these rights, please contact us using the information below.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-black text-white mb-3">Changes to This Privacy Policy</h2>
          <p class="text-slate-400 leading-relaxed">
            We may update this Privacy Policy periodically to reflect changes in our practices or for other operational, legal, or regulatory reasons. We encourage you to review this policy whenever you visit our website.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-black text-white mb-3">Contact Us</h2>
          <p class="text-slate-400 leading-relaxed mb-4">
            If you have any questions about this Privacy Policy or our privacy practices, please contact us:
          </p>
          <div class="space-y-2 text-slate-400">
            <p><strong class="text-white">{siteData.name}</strong></p>
            <p>
              Email: <a href={`mailto:${siteData.email}`} class="text-orange-400 hover:underline">{siteData.email}</a>
            </p>
            {siteData.phone && (
              <p>
                Phone: <a href={`tel:${siteData.phone}`} class="text-orange-400 hover:underline">{siteData.phone}</a>
              </p>
            )}
            <p>Jurisdiction: Vermont</p>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
