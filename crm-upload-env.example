# Copy this to .env for local dev — set these as env vars in Railway

# Password to log into the CRM dashboard
ADMIN_PASSWORD=your-strong-password-here

# Secret key for sessions (any random string, 32+ chars)
SESSION_SECRET=some-long-random-string-here

# Optional: secret token appended to the Netlify webhook URL for security
# Netlify webhook URL becomes: https://your-app.railway.app/webhook?secret=YOUR_WEBHOOK_SECRET
WEBHOOK_SECRET=another-random-string-here

# Path for the SQLite database file
# On Railway, set this to a path inside your persistent volume
# e.g. /data/leads.db
DB_PATH=./leads.db

# Port (Railway sets this automatically, don't change)
PORT=3000
